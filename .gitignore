# SimpleMotion .gitignore

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/
credentials/
.secrets/

# Claude Code
#.claude/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/
vendor/
.pnp/
.pnp.js

# Build outputs
dist/
build/
out/
*.egg-info/
__pycache__/
*.pyc
*.pyo

# Test coverage
coverage/
.nyc_output/
htmlcov/
.coverage
.pytest_cache/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak

# Package manager locks (uncomment if not needed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
